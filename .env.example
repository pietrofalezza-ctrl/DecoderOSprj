# Decoder — example environment.
# Copy to `.env` (never commit) and fill in values for local development.
# Public/publishable keys are safe to expose to the client; secrets are not.

# Lovable Cloud / Supabase project (public values used by the browser):
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-jwt"

# Same values re-exported with the VITE_ prefix so the client bundle can read them:
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-jwt"

# Server-only secrets (NEVER commit, NEVER prefix with VITE_):
# SUPABASE_SERVICE_ROLE_KEY="..."
# DECODER_ENCRYPTION_KEY="$(openssl rand -base64 32)"
# LOVABLE_API_KEY="..."
